{
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.vue"],
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "target": "esnext",
    "module": "esnext",
    "jsx": "preserve",
    "lib": ["esnext", "dom"],
    "types": [],
    "skipLibCheck": true,
    "useUnknownInCatchVariables": false,
    "paths": {
      "~/*": ["./src/*"]
    }
  }
}
